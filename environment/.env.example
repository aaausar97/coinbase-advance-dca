# --- Coinbase Advanced API credentials ---
# Generate at https://portal.cdp.coinbase.com/ (Trade + View permissions).
# IMPORTANT: This is the CDP-style key, NOT the legacy Coinbase Pro API/passphrase.
COINBASE_API_KEY=organizations/REPLACE/apiKeys/REPLACE
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nREPLACE\n-----END EC PRIVATE KEY-----\n"

# --- Runtime ---
# DRY_RUN=true simulates orders using live ticker prices. Set to false to trade real funds.
DRY_RUN=true
DATABASE_URL=sqlite://data/dca.db
TIMEZONE=America/New_York
LOG_LEVEL=INFO

# Per-asset daily safety cap (in USD). Total spend per asset since UTC midnight.
DCA_DAILY_CAP_USD=100

# --- DCA plans ---
# An asset is active only if BOTH _AMOUNT and _CRON are set.
# Cron is standard 5-field syntax (minute hour day-of-month month day-of-week).
# Examples:
#   "0 9 * * *"   -> daily at 9:00 (TIMEZONE)
#   "0 9 * * 1"   -> Mondays at 9:00
#   "0 9 1 * *"   -> 1st of each month at 9:00

DCA_BTC_USD_AMOUNT=10
DCA_BTC_USD_CRON=0 9 * * *

DCA_ETH_USD_AMOUNT=20
DCA_ETH_USD_CRON=0 9 * * 1

DCA_SOL_USD_AMOUNT=5
DCA_SOL_USD_CRON=0 9 1 * *
